{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BG3Guide",
  "version": "0.1.0",
  "identifier": "com.bg3guide.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "博德之门3 攻略工具",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 56,
        "resizable": true,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: *; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https:; connect-src *"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "data/*"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}